# claude-dev-team-toolkit configuration.
# Precedence (lowest to highest):  packaged defaults  <  project .claude/cdt.config.json  <  these env vars.
# All values are optional; the defaults below are the shipped defaults.

# --- Master switch ---------------------------------------------------------
CDT_ENABLED=true                       # false => all hooks no-op (fail-open)

# --- Prompt enhancement (UserPromptSubmit) ---------------------------------
CDT_PROMPT_ENHANCE=true                # enable prompt intake/enhancement
CDT_PROMPT_ENHANCE_MODE=auto           # auto | always | off   (auto = classifier decides if Haiku is called)
CDT_PROMPT_CONFIDENCE_THRESHOLD=0.75   # below this, prompt is "unclear" => consider enhancement
CDT_PROMPT_TIMEOUT_MS=12000            # Node-side timeout on the claude -p enhancer call (~8-10s observed cold start)
CDT_PROMPT_MODEL=claude-haiku-4-5      # model alias/id for the enhancer
CDT_PROMPT_EFFORT=medium               # enhancer reasoning effort (medium|high only); core CDT effort is separate (xhigh)
CDT_PROMPT_MIN_CHARS=40                # below this length => too short/simple => no Haiku
CDT_PROMPT_MAX_PER_SESSION=25          # circuit-breaker: max enhancer calls per session
CDT_PROMPT_MAX_USD=0.10                # hard --max-budget-usd ceiling per enhancer call (0.01 is below the per-call floor)
CDT_MAX_CONTEXT_CHARS=4000             # hard cap on injected additionalContext
# promptEnhancer.backend may be set in cdt.config.json to "haiku" (default) | "ollama" | "deterministic"
# LOCAL_PROMPT_MODEL=qwen3:8b          # only used when backend = ollama

# --- Requirement / spec extraction (cdt-spec) ------------------------------
CDT_SPEC_AUTO=false                    # auto-run cdt-spec on detected docs (off; the skill only suggests it)
CDT_EXTERNAL_AI_ALLOWED=false          # allow external-AI assist during spec extraction (still gated by approval + sensitivity)
CDT_OCR_ENABLED=false                  # enable LOCAL on-device OCR (tesseract.js); independent of external AI

# --- Safety / redaction ----------------------------------------------------
CDT_REDACT=true                        # mask secrets/PII in every artifact + injected context

# --- Verification ----------------------------------------------------------
CDT_VERIFY_DOCS_EXEMPT=true            # docs/plan-only sessions => verification:not_run (never a global "verify off")
