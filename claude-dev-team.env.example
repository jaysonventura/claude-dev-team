# claude-dev-team configuration
#
# Copy this file to ~/.claude/claude-dev-team.env and set values by hand, or use the `cdt-config` CLI
# (most keys below are also settable via `cdt-config`). This file is a documentation template.

# --- Task Loop ---
# Max fix iterations before stopping (protects Max 5x rate limits)
CDT_MAX_ITERATIONS=5

# --- Verification gate (set via cdt-config verify; shown here for reference) ---
# Block a session from ending if it edited files but ran no test/build/lint/typecheck afterward —
# structurally stops a false "done". block = hard-block once per session · warn = notice only · off.
CDT_VERIFY_GATE=block
# Require the verifying command to have actually produced output (1) — a "command not found" doesn't
# count as verification. Set 0 to mark verified on any matching command regardless of its result.
CDT_VERIFY_REQUIRE_OUTPUT=1

# --- Scope/sprawl gate (set via cdt-config scope; shown here for reference) ---
# Flag when a dispatched subagent wrote files OUTSIDE its exclusive-file contract (overreach) or into a
# peer's scope (collision). warn = surface a notice at Stop · block = stop until reconciled · off.
# Requires the orchestrator to emit a `CDT-CONTRACT: exclusive=...` line per dispatch (see the skill).
CDT_SCOPE_GATE=warn

# --- Memory gate + recall ranking (set via cdt-config memory; weights shown for reference) ---
# Nudge a TEAM-tier session (it dispatched >=1 specialist) that edited files but persisted no vault
# lesson. warn = nudge at Stop · block = stop until a lesson is recorded · off. Solo T0/T1 work is exempt.
CDT_MEMORY_GATE=warn
# cdt-recall re-ranks relevant lessons by recency (newer wins) + outcome (terms seen in painful past
# tasks rank higher). Tunable weights / half-life (days):
CDT_RECALL_RECENCY_WEIGHT=2
CDT_RECALL_OUTCOME_WEIGHT=1.5
CDT_RECALL_HALFLIFE_DAYS=180

# --- Autonomous Agent Orchestration (set via cdt-config; shown here for reference) ---
# Autonomy leash: off = bounded only · assist = auto-summon agent-teams, ask before workflows ·
# auto = self-run both within the budget ceiling. Engines ship off; enable per machine.
CDT_AUTONOMY=assist
CDT_TEAMS=off          # DEPTH — agent-team Bug Council (also sets CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS)
CDT_SCALE=off          # BREADTH — dynamic-workflow Scale mode (needs Claude Code >= 2.1.154)
# Cost-governor caps (the orchestrator consults `cdt-auto gate` before any escalation):
CDT_AUTONOMY_WEEKLY_CEILING=85    # pause to ASK at/above this weekly usage %
CDT_TEAM_MAX=5                    # max teammates in a debating council
CDT_SCALE_TOKEN_CAP=2000000       # stop a workflow run if projected to exceed this many tokens

# --- Parallel dispatch (Parallel Orchestration v2) ---
# Give each strand of a parallel multi-writer wave (>=2 concurrent writers; any T2+ build wave, all T3)
# its own git worktree so writes can't collide and agents run truly in parallel. Set 0 to force in-place
# dispatch (single-writer waves and T0/T1 stay in-place regardless). The orchestrator also sizes the wave
# with `cdt-auto fanout <tier>` (full width when there's budget headroom; trims toward the floor near the
# weekly ceiling, never below security-review + qa verify).
CDT_WORKTREE_DEFAULT=1

# --- Menu bar app (macOS) ---
# Auto-build + launch + enable login auto-start for the menu bar monitor on macOS. Set 0 to disable.
CDT_MENUBAR_AUTO=1
